{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "c8a459318d7742b382bd1927191f5f91",
    "m_Title": "ProPixelizer SubTarget",
    "m_Content": "This ShaderGraph is using the ProPixelizer SubTarget, which you can select via the Graph Inspector -> Graph Settings.\n\nThe ProPixelizer SubTarget behaves like a standard 'lit' ShaderGraph, but with a lot of extra options! The SubTarget automatically implements a number of features for you:\n- Cel shading using a supplied lighting ramp to quantise lighting.\n- Color grading and dither patterns.\n- Pixel expansion.\n- Edge, ID and Bevel outlines, which can be controlled per-pixel using the ProPixelizer fields on your ShaderGraph output.\n\nYou'll also find that the SubTarget will automatically add required ProPixelizer properties and keywords to your material.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1247.3333740234375,
        "y": -38.66666793823242,
        "width": 675.3333740234375,
        "height": 182.6666717529297
    },
    "m_Group": {
        "m_Id": ""
    }
}

